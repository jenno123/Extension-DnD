# Port the relay listens on (HTTP + WebSocket share this port).
PORT=8787

# Absolute or relative path to the config directory that holds
# campaign.json and the portraits/ folder. Defaults to ../../config.
CONFIG_DIR=../../config

# Optional shared secret. If set, the discord-listener must send the same
# value as ?token=... when it connects as the event source. Leave blank to
# disable (fine for a private game behind a tunnel).
RELAY_TOKEN=
