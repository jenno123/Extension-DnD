# From the Discord Developer Portal (https://discord.com/developers/applications)
# These belong to the HOST only. Players never need them.
DISCORD_CLIENT_ID=your_application_client_id
DISCORD_CLIENT_SECRET=your_application_client_secret

# Must be listed under OAuth2 -> Redirects in the Developer Portal.
# Any value works for the local RPC flow; this default is conventional.
DISCORD_REDIRECT_URI=http://localhost

# Where the relay is reachable. ws:// for local, wss:// through a tunnel/VPS.
RELAY_URL=ws://localhost:8787

# Optional shared secret. Must match the relay's RELAY_TOKEN if that is set.
RELAY_TOKEN=
